@model BandwidthTemplatesViewModel
@{
    ViewData["Title"] = "Templates";
}

<section class="hero-panel">
    <div>
        <p class="eyebrow">Administration</p>
        <h1>Bandwidth templates</h1>
        <p class="muted hero-copy">Manage separate reusable presets for download and upload limits. These values are global for the whole UnifiPlus instance.</p>
    </div>
    <div class="hero-badge">
        <span>Persistent store</span>
        <strong>@Model.StoragePath</strong>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="@(Model.StatusIsSuccess ? "flash-success" : "flash-error")">@Model.StatusMessage</div>
}

<section class="grid two-up">
    <article class="card card-strong">
        <div class="section-head">
            <div>
                <p class="eyebrow">Download</p>
                <h2>Download templates</h2>
            </div>
            <span class="badge">@Model.DownloadTemplatesMbps.Count value(s)</span>
        </div>

        <div class="template-chip-list">
            @foreach (var value in Model.DownloadTemplatesMbps)
            {
                <span class="template-chip template-chip-static">@value Mbit</span>
            }
        </div>

        <div class="card-actions">
            <a asp-action="EditTemplate" asp-route-type="Download" class="icon-link strong-ghost">
                <span class="action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                    </svg>
                </span>
                <span class="action-label">Edit download templates</span>
            </a>
        </div>
    </article>

    <article class="card">
        <div class="section-head">
            <div>
                <p class="eyebrow">Upload</p>
                <h2>Upload templates</h2>
            </div>
            <span class="badge">@Model.UploadTemplatesMbps.Count value(s)</span>
        </div>

        <div class="template-chip-list">
            @foreach (var value in Model.UploadTemplatesMbps)
            {
                <span class="template-chip template-chip-static">@value Mbit</span>
            }
        </div>

        <div class="card-actions">
            <a asp-action="EditTemplate" asp-route-type="Upload" class="icon-link strong-ghost">
                <span class="action-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 20h9"></path>
                        <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"></path>
                    </svg>
                </span>
                <span class="action-label">Edit upload templates</span>
            </a>
        </div>
    </article>
</section>

<section class="card">
    <div class="record-note">
        Last updated: @(Model.LastUpdatedUtc?.ToLocalTime().ToString("g") ?? "Never")
    </div>
</section>
