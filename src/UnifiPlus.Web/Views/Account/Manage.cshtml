@model AccountViewModel
@{
    ViewData["Title"] = "Account";
}

<section class="account-summary">
    <div class="account-summary-copy">
        <p class="eyebrow">Profile</p>
        <h1>@Model.DisplayName</h1>
        <p class="muted">Manage your password and claim the UniFi clients that belong to you.</p>
    </div>
    <div class="account-summary-meta">
        <span class="badge">@Model.Role</span>
    </div>
</section>

@if (TempData["PasswordChanged"] is string message)
{
    <div class="flash-success">@message</div>
}

@if (TempData["ActionStatus"] is string actionStatus)
{
    <div class="flash-success">@actionStatus</div>
}

@if (TempData["ActionError"] is string actionError)
{
    <div class="flash-error">@actionError</div>
}

@if (TempData["ApiKeyStatus"] is string apiKeyStatus)
{
    <div class="flash-success">@apiKeyStatus</div>
}

@if (TempData["ApiKeyPlaintext"] is string apiKeyPlaintext)
{
    <div class="flash-success">
        <strong>Copy this API key now:</strong>
        <code>@apiKeyPlaintext</code>
    </div>
}

<section class="account-shell">
<section class="compact-two-up">
    <article class="card card-strong compact-card">
        <div class="section-head">
            <div>
                <p class="eyebrow">Security</p>
                <h2>Password</h2>
            </div>
        </div>

        <form asp-action="ChangePassword" method="post" class="stack compact-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation"></div>

            <label asp-for="PasswordForm.CurrentPassword"></label>
            <input asp-for="PasswordForm.CurrentPassword" />

            <label asp-for="PasswordForm.NewPassword"></label>
            <input asp-for="PasswordForm.NewPassword" />

            <label asp-for="PasswordForm.ConfirmPassword"></label>
            <input asp-for="PasswordForm.ConfirmPassword" />

            <div class="card-actions">
                <button type="submit" class="action-button">
                    <span class="action-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="10" rx="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </span>
                    <span class="action-label">Change password</span>
                </button>
            </div>
        </form>
    </article>

    <article class="card compact-card">
        <div class="section-head">
            <div>
                <p class="eyebrow">Live uplinks</p>
                <h2>Available uplinks</h2>
            </div>
        </div>

        @if (Model.AvailableWans.Count == 0)
        {
            <p class="muted">No live UniFi uplinks are currently available.</p>
        }
        else
        {
            <div class="compact-pill-grid">
                @foreach (var wan in Model.AvailableWans)
                {
                    <span class="compact-pill @(wan.IsActive ? "compact-pill-active" : string.Empty)">@wan.Name</span>
                }
            </div>
        }
    </article>

    <article class="card compact-card">
        <div class="section-head">
            <div>
                <p class="eyebrow">Devices</p>
                <h2>Open device management</h2>
            </div>
        </div>

        <p class="muted">Open the dedicated devices page to manage your aliases, uplinks, bandwidth limits and claimable clients.</p>

        <div class="card-actions">
            <a asp-action="Devices" class="icon-link strong-ghost">
                <span class="action-label">Open devices</span>
            </a>
        </div>
    </article>

    <article class="card compact-card">
        <div class="section-head">
            <div>
                <p class="eyebrow">Developer</p>
                <h2>API keys</h2>
            </div>
        </div>

        <div class="surface-note">
            Keys are shown once on creation and stay tied to your account page. Use them later for the tray app or direct REST calls.
        </div>

        <form asp-action="CreateApiKey" method="post" class="stack compact-form">
            @Html.AntiForgeryToken()

            <label asp-for="ApiKeyForm.Name"></label>
            <input asp-for="ApiKeyForm.Name" placeholder="Tray app on office PC" />
            <div class="field-hint">Use the key later as <strong>X-API-Key</strong> header or Bearer token for `/api/v1/...` requests.</div>

            <div class="card-actions">
                <button type="submit" class="action-button">
                    <span class="action-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 5v14"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </span>
                    <span class="action-label">Create API key</span>
                </button>
            </div>
        </form>

        @if (Model.ApiKeys.Count == 0)
        {
            <p class="muted section-spaced">No API keys created yet.</p>
        }
        else
        {
            <div class="compact-record-list section-spaced">
                @foreach (var apiKey in Model.ApiKeys)
                {
                    <div class="compact-record">
                        <div class="record-header">
                            <div class="record-title">
                                <strong>@apiKey.Name</strong>
                                <div class="record-note">Prefix: @apiKey.KeyPrefix...</div>
                            </div>
                            <span class="badge">@((apiKey.IsRevoked ? "Revoked" : "Active"))</span>
                        </div>
                        <div class="compact-record-meta">
                            <span>Created: @apiKey.CreatedUtc.ToLocalTime().ToString("g")</span>
                            <span>Last used: @(apiKey.LastUsedUtc?.ToLocalTime().ToString("g") ?? "Never")</span>
                        </div>
                        @if (!apiKey.IsRevoked)
                        {
                            <form asp-action="RevokeApiKey" method="post" class="compact-inline-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="KeyId" value="@apiKey.Id" />
                                <div class="card-actions card-actions-end">
                                    <button type="submit" class="action-button action-button-danger action-button-small">
                                        <span class="action-icon" aria-hidden="true">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M3 6h18"></path>
                                                <path d="M8 6V4h8v2"></path>
                                                <path d="M19 6l-1 14H6L5 6"></path>
                                                <path d="M10 11v6"></path>
                                                <path d="M14 11v6"></path>
                                            </svg>
                                        </span>
                                        <span class="action-label">Revoke</span>
                                    </button>
                                </div>
                            </form>
                        }
                    </div>
                }
            </div>
        }
    </article>
</section>

</section>
